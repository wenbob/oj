{
  "name": "cpp-oj-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npm run check:env && node --import ./scripts/load-env.mjs .next/standalone/server.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db execute --file prisma/init.sql --schema prisma/schema.prisma",
    "db:init": "prisma generate && prisma db execute --file prisma/init.sql --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:baseline": "prisma migrate resolve --applied 0001_initial",
    "backup:sqlite": "powershell -ExecutionPolicy Bypass -File scripts/backup-sqlite.ps1",
    "check:env": "tsx scripts/check-env.ts",
    "admin:password": "tsx scripts/change-admin-password.ts",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.13",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
